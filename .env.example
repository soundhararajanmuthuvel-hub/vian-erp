# ==========================================
# VIAN ERP - Backend Production Environment
# ==========================================

PORT=5050
NODE_ENV=production

# Database Configuration (MySQL)
# Option A: Connection string
DATABASE_URL=mysql://root:password@127.0.0.1:3306/vian_architects_db

# Option B: Individual component details
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=vian_architects_db
DB_USER=root
DB_PASSWORD=password

# Developer fallback options
AUTO_FALLBACK_SQLITE=true

# JWT Authentication
JWT_SECRET=production_jwt_secret_key_change_me
JWT_REFRESH_SECRET=production_jwt_refresh_secret_key_change_me

# Google Gemini API
GEMINI_API_KEY=your_gemini_api_key_here

# Cloudinary Integration
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Maps
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Email configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=office@vianarchitects.in
EMAIL_PASS=your_email_password_here

# Client URL
CLIENT_URL=https://erp.vianarchitects.in

# ==========================================
# VIAN ERP - Frontend Environment
# ==========================================

API_URL=https://api.vianarchitects.in
APP_NAME=VIAN ERP
APP_VERSION=1.0.0
